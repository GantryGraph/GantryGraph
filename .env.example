# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one is required. Pass the chosen model to ClawEngine(llm=...).

ANTHROPIC_API_KEY=sk-ant-...          # Claude (recommended: claude-sonnet-4-6)
OPENAI_API_KEY=sk-...                 # GPT-4o, o1
GOOGLE_API_KEY=...                    # Gemini

# ── Agent runtime (ClawConfig / ClawEngine) ────────────────────────────────────
CLAW_MAX_STEPS=50
CLAW_WORKSPACE=/tmp/agent-workspace
CLAW_MEMORY=in_memory                 # none | in_memory | chroma
CLAW_ENABLE_SUSPENSION=false
CLAW_GUARDRAIL_REQUIRES_APPROVAL=     # comma-separated tool names, e.g.: shell_run,file_delete

# ── Persistent memory (only if CLAW_MEMORY=chroma) ────────────────────────────
CLAW_MEMORY_PERSIST_DIRECTORY=/tmp/claw-memory
CLAW_MEMORY_COLLECTION=claw_memory

# ── Telemetry / OTel (optional) ───────────────────────────────────────────────
# Leave blank to disable. When set, spans are exported to this OTLP gRPC endpoint.
# Compatible: Grafana Alloy, Datadog Agent, Jaeger, Zipkin.
CLAW_TELEMETRY_OTLP_ENDPOINT=
CLAW_TELEMETRY_SERVICE_NAME=claw-agent

# ── Browser / Playwright (only with [browser] extra) ──────────────────────────
# Leave blank to use Chromium headless (default).
PLAYWRIGHT_BROWSERS_PATH=             # custom browser install path

# ── Shell tool ────────────────────────────────────────────────────────────────
CLAW_SHELL_TIMEOUT=30
# Comma-separated allowlist. Empty = allow all executables.
CLAW_SHELL_ALLOWED_COMMANDS=

# ── MCP servers (optional — can also be passed at runtime) ────────────────────
# Example values used in documentation / examples:
# MCP_FILESYSTEM_CMD=npx -y @modelcontextprotocol/server-filesystem /tmp
# MCP_GITHUB_CMD=npx -y @modelcontextprotocol/server-github
